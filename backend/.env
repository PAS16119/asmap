# Copy this file to .env and fill in your values
# Never commit .env to version control

FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key
JWT_SECRET_KEY=change-this-to-another-random-key

# SQLite for local development (default — no change needed)
# DATABASE_URL=sqlite:///asmap_dev.db

# PostgreSQL for production (uncomment and fill in)
# DATABASE_URL=postgresql://user:password@host:5432/asmap_db
